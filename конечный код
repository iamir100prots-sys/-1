    std::cout << std::endl;
    std::cout << "========================================" << std::endl;
    std::cout << "         SiteBlocker - Меню" << std::endl;
    std::cout << "========================================" << std::endl;
    std::cout << "  1. Заблокировать сайт(ы)" << std::endl;
    std::cout << "  2. Список заблокированных сайтов" << std::endl;
    std::cout << "  3. Разблокировать сайт вручную" << std::endl;
    std::cout << "  4. Выход" << std::endl;
    std::cout << "========================================" << std::endl;
    std::cout << "Выберите действие: ";
}

static void ShowBlockedList() {
    std::lock_guard<std::mutex> lock(g_mutex);
    if (g_blockedSites.empty()) {
        std::cout << "  Список блокировки пуст." << std::endl;
        return;
    }
    time_t now = time(nullptr);
    std::cout << std::endl;
    for (size_t i = 0; i < g_blockedSites.size(); i++) {
        auto& s = g_blockedSites[i];
        int remaining = BLOCK_DURATION_SEC - (int)(now - s.blockedAt);
        if (remaining < 0) remaining = 0;
        int hours = remaining / 3600;
        int mins = (remaining % 3600) / 60;
        std::cout << "  " << (i + 1) << ". " << s.domain
            << "  (заблокирован: " << TimeToStr(s.blockedAt)
            << ", осталось: " << hours << "ч " << mins << "м)" << std::endl;
        for (auto& ip : s.ips)
            std::cout << "     IP: " << ip << std::endl;
    }
}

static bool InitWinsock() {
    WSADATA wsaData;
    return WSAStartup(MAKEWORD(2, 2), &wsaData) == 0;
}

int main() {
    SetConsoleOutputCP(65001);
    SetConsoleCP(65001);

    std::cout << "========================================" << std::endl;
    std::cout << "  SiteBlocker v1.0" << std::endl;
    std::cout << "  Блокировка сайтов на 24 часа" << std::endl;
    std::cout << "  Метод: брандмауэр Windows" << std::endl;
    std::cout << "========================================" << std::endl;

    if (!IsRunAsAdmin()) {
        std::cout << std::endl;
        std::cout << "  ОШИБКА: Программа должна быть запущена" << std::endl;
        std::cout << "  от имени администратора!" << std::endl;
        std::cout << "  Нажмите Enter для выхода..." << std::endl;
        std::cin.get();
        return 1;
    }

    if (!InitWinsock()) {
        std::cout << "  Ошибка инициализации сети." << std::endl;
        return 1;
    }

    LoadData();
    CleanupExpired();

    if (!g_blockedSites.empty()) {
        std::cout << std::endl;
        std::cout << "  Загружено активных блокировок: " << g_blockedSites.size() << std::endl;
    }

    std::thread bgThread(AutoUnblockThread);

    while (true) {
        ShowMenu();

        std::string choice;
        std::getline(std::cin, choice);

        if (choice == "1") {
            std::cout << std::endl;
            std::cout << "  Введите домен(ы) для блокировки" << std::endl;
            std::cout << "  (через пробел, например: vk.com youtube.com):" << std::endl;
            std::cout << "  > ";

            std::string input;
            std::getline(std::cin, input);

            std::istringstream iss(input);
            std::string domain;
            std::vector<std::string> domains;
            while (iss >> domain)
                domains.push_back(domain);

            if (domains.empty()) {
                std::cout << "  Не указано ни одного домена." << std::endl;
                continue;
            }

            std::lock_guard<std::mutex> lock(g_mutex);
            for (auto& d : domains) {
                if (d.find("://") != std::string::npos)
                    d = d.substr(d.find("://") + 3);
                while (!d.empty() && d.back() == '/')
                    d.pop_back();

                std::string withoutWww = d;
                std::string withWww = d;
                if (d.substr(0, 4) == "www.")
                    withoutWww = d.substr(4);
                else
                    withWww = "www." + d;

                std::cout << std::endl;
                BlockSite(withoutWww);
                BlockSite(withWww);
            }
        }
        else if (choice == "2") {
            ShowBlockedList();
        }
        else if (choice == "3") {
            std::cout << std::endl;
            std::cout << "  Введите домен для разблокировки: ";
            std::string domain;
            std::getline(std::cin, domain);
            if (!domain.empty()) {
                if (domain.find("://") != std::string::npos)
                    domain = domain.substr(domain.find("://") + 3);
                while (!domain.empty() && domain.back() == '/')
                    domain.pop_back();

                std::string withoutWww = domain;
                std::string withWww = domain;
                if (domain.substr(0, 4) == "www.")
                    withoutWww = domain.substr(4);
                else
                    withWww = "www." + domain;

                ManualUnblock(withoutWww);
                ManualUnblock(withWww);
            }
        }
        else if (choice == "4") {
            std::cout << std::endl;
            std::cout << "  Завершение работы..." << std::endl;
            std::cout << "  Блокировки остаются активными." << std::endl;
            std::cout << "  Они будут сняты автоматически при следующем запуске" << std::endl;
            std::cout << "  программы по истечении 24 часов." << std::endl;
            break;
        }
        else {
            std::cout << "  Неверный выбор." << std::endl;
        }
    }

    g_running = false;
    if (bgThread.joinable())
        bgThread.join();

    WSACleanup();
    return 0;
}   
